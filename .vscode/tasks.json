{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "npm",
      "script": "watch:extension",
      "problemMatcher": {
        "owner": "custom",
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^\\[esbuild\\] Build starting\\.\\.\\.",
          "endsPattern": "^\\[esbuild\\] Extension build succeeded\\."
        }
      },
      "isBackground": true,
      "presentation": {
        "reveal": "never"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}
