{
  "name": "opico-agent",
  "displayName": "Opico Agent",
  "description": "An autonomous AI coding agent for VS Code",
  "version": "0.1.0",
  "publisher": "opico",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "AI",
    "Programming Languages",
    "Other"
  ],
  "activationEvents": [],
  "icon": "resources/logo.svg",
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "opico-agent-sidebar",
          "title": "Opico Agent",
          "icon": "resources/logo.svg"
        }
      ]
    },
    "views": {
      "opico-agent-sidebar": [
        {
          "type": "webview",
          "id": "opico-agent.chatView",
          "name": "Chat"
        }
      ]
    },
    "commands": [
      {
        "command": "opico-agent.openChat",
        "title": "Opico Agent: Open Chat"
      }
    ],
    "configuration": {
      "title": "Opico Agent",
      "properties": {
        "opico-agent.modelProvider": {
          "type": "string",
          "default": "anthropic",
          "description": "The AI provider to use."
        },
        "opico-agent.modelName": {
          "type": "string",
          "default": "claude-3-5-sonnet-20241022",
          "description": "The model name to use."
        },
        "opico-agent.apiKey": {
          "type": "string",
          "default": "",
          "description": "Optional API key for the selected provider."
        },
        "opico-agent.apiBaseUrl": {
          "type": "string",
          "default": "",
          "description": "Optional custom base URL for OpenAI-compatible providers."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build:extension": "node esbuild.js --production",
    "build:webview": "cd webview && npm run build",
    "build": "npm-run-all build:extension build:webview",
    "watch:extension": "node esbuild.js --watch",
    "watch:webview": "cd webview && npm run dev",
    "dev": "npm-run-all --parallel watch:extension watch:webview",
    "compile": "node esbuild.js",
    "lint": "eslint src --ext ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.74",
    "@ai-sdk/google": "^3.0.67",
    "@ai-sdk/google-vertex": "^4.0.118",
    "@ai-sdk/openai": "^3.0.58",
    "@ai-sdk/openai-compatible": "^2.0.45",
    "@vscode/ripgrep": "^1.17.1",
    "ai": "^6.0.174",
    "diff": "^9.0.0",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@types/diff": "^7.0.2",
    "@types/node": "^25.6.0",
    "@types/vscode": "^1.118.0",
    "esbuild": "^0.28.0",
    "npm-run-all": "^4.1.5",
    "typescript": "^6.0.3"
  }
}
